# ============================================================
# SWG:L Loadout Tool — Environment Configuration
# Copy to .env and fill in values before deploying
# ============================================================

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=slt_db
POSTGRES_USER=slt_user
POSTGRES_PASSWORD=CHANGE_ME_TO_RANDOM_PASSWORD

# Full connection string (constructed from above in compose)
DATABASE_URL=postgresql://slt_user:CHANGE_ME@db:5432/slt_db

# ── Authentication ───────────────────────────────────────────
# IMPORTANT: Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET

# ── Application ──────────────────────────────────────────────
# Set to "production" in prod — enforces SECRET_KEY requirement
ENV=production
LOG_LEVEL=info

# ── Ports ────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Docker Image (for production compose pulling from registry)
# REGISTRY=ghcr.io
# IMAGE_NAME=your-org/seraphs-loadout-tool
# IMAGE_TAG=latest


STAGING_HTTP_PORT=8080
STAGING_HTTPS_PORT=8443
STAGING_POSTGRES_DB=slt_staging_db
STAGING_POSTGRES_USER=slt_staging_user
STAGING_IMAGE_TAG=staging
LOG_LEVEL=info
# ── Discord OAuth (Optional) ─────────────────────────────────
# PUBLIC_BASE_URL should be the public frontend origin, without a trailing slash
PUBLIC_BASE_URL=https://your-domain.example
# Optional explicit CORS allow-list. Comma separated. Defaults to PUBLIC_BASE_URL in production.
CORS_ALLOWED_ORIGINS=https://your-domain.example
# Optional cookie domain if frontend/API span subdomains. Leave blank for same-host deployments.
SESSION_COOKIE_DOMAIN=
# Server-side minimum password length
PASSWORD_MIN_LENGTH=10
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Defaults to {PUBLIC_BASE_URL}/api/auth/discord/callback if left blank
DISCORD_REDIRECT_URI=

# ── Transactional Email (Optional, required for forgot password) ────────
# Supported providers: resend, postmark
# If EMAIL_PROVIDER is left blank, the backend auto-selects Resend when configured,
# otherwise Postmark when configured.
EMAIL_PROVIDER=resend

# Resend (recommended)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@your-domain.example
RESEND_REPLY_TO_EMAIL=

# Postmark (optional legacy fallback)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=noreply@your-domain.example
POSTMARK_MESSAGE_STREAM=outbound

# ── Prometheus / Grafana Cloud Metrics (Optional) ─────────────────
# Enable backend metrics endpoint and protect it with basic auth
METRICS_ENABLED=false
METRICS_PATH=/api/metrics
METRICS_BASIC_AUTH_USERNAME=metrics
METRICS_BASIC_AUTH_PASSWORD=CHANGE_ME_TO_LONG_RANDOM_PASSWORD

# Grafana Cloud Prometheus remote_write details
# Example URL format:
# https://prometheus-prod-<region>.grafana.net/api/prom/push
GRAFANA_CLOUD_METRICS_URL=
GRAFANA_CLOUD_METRICS_USER_ID=
# Optional separate token for metrics. If left blank, compose falls back to GRAFANA_CLOUD_API_KEY if defined.
GRAFANA_CLOUD_METRICS_API_KEY=
PROMETHEUS_SCRAPE_INTERVAL=15s

# ── Curated Mods Upload Safety ───────────────────────────────
MAX_MOD_FILE_SIZE=10485760
MAX_SCREENSHOT_SIZE=2097152
MAX_MOD_UPLOAD_BATCH=10
