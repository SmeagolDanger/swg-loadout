# ============================================================
# SWG:L Loadout Tool — Environment Configuration
# Copy to .env and fill in values before deploying
# ============================================================

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=slt_db
POSTGRES_USER=slt_user
POSTGRES_PASSWORD=CHANGE_ME_TO_RANDOM_PASSWORD

# Full connection string (constructed from above in compose)
DATABASE_URL=postgresql://slt_user:CHANGE_ME@db:5432/slt_db

# ── Authentication ───────────────────────────────────────────
# IMPORTANT: Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET

# ── Application ──────────────────────────────────────────────
# Set to "production" in prod — enforces SECRET_KEY requirement
ENV=production
LOG_LEVEL=info

# ── Ports ────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Docker Image (for production compose pulling from registry)
# REGISTRY=ghcr.io
# IMAGE_NAME=your-org/seraphs-loadout-tool
# IMAGE_TAG=latest


STAGING_HTTP_PORT=8080
STAGING_HTTPS_PORT=8443
STAGING_POSTGRES_DB=slt_staging_db
STAGING_POSTGRES_USER=slt_staging_user
STAGING_IMAGE_TAG=staging
LOG_LEVEL=info
# ── Discord OAuth (Optional) ─────────────────────────────────
# PUBLIC_BASE_URL should be the public frontend origin, without a trailing slash
PUBLIC_BASE_URL=https://your-domain.example
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Defaults to {PUBLIC_BASE_URL}/api/auth/discord/callback if left blank
DISCORD_REDIRECT_URI=

# ── Postmark Email (Optional, required for forgot password) ────────
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=noreply@your-domain.example
POSTMARK_MESSAGE_STREAM=outbound


# ── Observability Provider Toggle ───────────────────────────
# Supported values: none, better_stack, grafana_cloud
OBSERVABILITY_PROVIDER=none
OBSERVABILITY_SERVICE_NAME=backend
OBSERVABILITY_INCLUDE_ACCESS_LOGS=false
OBSERVABILITY_INCLUDE_HEALTHCHECKS=false
OBSERVABILITY_REMOTE_TIMEOUT_S=3.0
OBSERVABILITY_REMOTE_BATCH_SIZE=25
OBSERVABILITY_REMOTE_FLUSH_INTERVAL_S=2.0

# Better Stack (used when OBSERVABILITY_PROVIDER=better_stack)
BETTER_STACK_SOURCE_TOKEN=
BETTER_STACK_INGESTING_HOST=
# Optional full override URL if Better Stack gives you a full endpoint
BETTER_STACK_HTTP_API_URL=

# Grafana Cloud Logs (used when OBSERVABILITY_PROVIDER=grafana_cloud)
# Example URL format from Grafana Cloud: https://logs-prod-<region>.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOGS_URL=
# Numeric/stack-specific logs instance user ID from Grafana Cloud
GRAFANA_CLOUD_LOGS_USER_ID=
# Cloud Access Policy token / API key with logs:write scope
GRAFANA_CLOUD_API_KEY=
GRAFANA_CLOUD_LOGS_JOB=backend

# Optional Prometheus metrics endpoint for Grafana Cloud or other scrapers
METRICS_ENABLED=false
METRICS_BASIC_AUTH_USERNAME=
METRICS_BASIC_AUTH_PASSWORD=
