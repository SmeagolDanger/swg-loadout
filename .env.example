# ============================================================
# SWG:L Loadout Tool — Environment Configuration
# Copy to .env and fill in values before deploying
# ============================================================

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=slt_db
POSTGRES_USER=slt_user
POSTGRES_PASSWORD=CHANGE_ME_TO_RANDOM_PASSWORD

# Full connection string (constructed from above in compose)
DATABASE_URL=postgresql://slt_user:CHANGE_ME@db:5432/slt_db

# ── Authentication ───────────────────────────────────────────
# IMPORTANT: Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET

# ── Application ──────────────────────────────────────────────
# Set to "production" in prod — enforces SECRET_KEY requirement
ENV=production
LOG_LEVEL=info

# ── Ports ────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Docker Image (for production compose pulling from registry)
# REGISTRY=ghcr.io
# IMAGE_NAME=your-org/seraphs-loadout-tool
# IMAGE_TAG=latest


STAGING_HTTP_PORT=8080
STAGING_HTTPS_PORT=8443
STAGING_POSTGRES_DB=slt_staging_db
STAGING_POSTGRES_USER=slt_staging_user
STAGING_IMAGE_TAG=staging
LOG_LEVEL=info
# ── Discord OAuth (Optional) ─────────────────────────────────
# PUBLIC_BASE_URL should be the public frontend origin, without a trailing slash
PUBLIC_BASE_URL=https://your-domain.example
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Defaults to {PUBLIC_BASE_URL}/api/auth/discord/callback if left blank
DISCORD_REDIRECT_URI=

# ── Postmark Email (Optional, required for forgot password) ────────
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=noreply@your-domain.example
POSTMARK_MESSAGE_STREAM=outbound

# ── Better Stack Logging (Optional) ─────────────────────────
# Create a Logs source in Better Stack, then copy the source token and ingesting host.
BETTER_STACK_ENABLED=true
BETTER_STACK_SOURCE_TOKEN=
# Example: s12345.eu-nbg-2.betterstackdata.com
BETTER_STACK_INGESTING_HOST=
# Alternative to BETTER_STACK_INGESTING_HOST if Better Stack gives you a full URL
BETTER_STACK_HTTP_API_URL=
# Leave blank to reuse LOG_LEVEL
BETTER_STACK_LOG_LEVEL=
# Keep these false unless you explicitly want high-volume request noise in Better Stack
BETTER_STACK_INCLUDE_ACCESS_LOGS=false
BETTER_STACK_INCLUDE_HEALTHCHECKS=false
